# VoxScript POC — Environment Variables
# Copy this to .env and adjust values for your machine

# Database
DATABASE_URL=postgresql+asyncpg://voxscript:voxscript@localhost:5432/voxscript
DATABASE_URL_SYNC=postgresql://voxscript:voxscript@localhost:5432/voxscript

# ASR Model — change these if your GPU has issues
# Options: large-v3-turbo, medium, small
ASR_MODEL=large-v3-turbo
ASR_DEVICE=cuda
# Options: float16, int8_float16, int8
# Use int8_float16 for 6GB VRAM, float16 if you have 8GB+
ASR_COMPUTE_TYPE=int8_float16

# Frontend
FRONTEND_ORIGIN=http://localhost:3000

# Debug
DEBUG=true
